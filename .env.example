# HuggingFace token for TRIBE v2 model access
# Get your token at https://huggingface.co/settings/tokens
# You must also accept the Meta LLaMA 3.2 license at https://huggingface.co/meta-llama
NEUROSCORE_HF_TOKEN=hf_your_token_here

# Anthropic API key for LLM-powered video analysis
# Get your key at https://console.anthropic.com/settings/keys
NEUROSCORE_ANTHROPIC_API_KEY=sk-ant-your_key_here
